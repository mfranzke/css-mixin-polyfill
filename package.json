{
  "name": "css-mixin-polyfill-monorepo",
  "version": "",
  "type": "module",
  "description": "A JavaScript polyfill and PostCSS plugin for CSS @mixin, @macro, and @apply rules",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mfranzke/css-mixin-polyfill.git"
  },
  "homepage": "https://mfranzke.github.io/css-mixin-polyfill/",
  "bugs": {
    "url": "https://github.com/mfranzke/css-mixin-polyfill/issues"
  },
  "author": "Maximilian Franzke",
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
  "engines": {
    "node": ">= 22"
  },
  "keywords": [
    "css",
    "polyfill",
    "mixin",
    "macro",
    "apply",
    "at-rule",
    "reusable-styles"
  ],
  "scripts": {
    "build": "pnpm --recursive run build",
    "build:docs": "node scripts/build-docs.js",
    "changeset": "changeset",
    "changeset:publish": "pnpm run build && pnpm exec changeset publish",
    "changeset:version": "changeset version && pnpm install --lockfile-only && prettier '{CHANGELOG.md,packages/*/CHANGELOG.md}' --write",
    "codestyle": "prettier . --write",
    "dev": "pnpm --recursive run dev",
    "lint": "npm-run-all --parallel lint:*",
    "lint:markdownlint": "markdownlint --config .config/.markdown-lint.yml **/*.md",
    "lint:packages": "publint packages/css-mixin-polyfill && publint packages/postcss-transform-mixins && publint packages/stylelint-config-mixin",
    "lint:stylelint:14": "pnpm dlx stylelint@14 test/fixtures/*.input.css --config .config/.stylelintrc.older.json",
    "lint:stylelint:15": "pnpm dlx stylelint@15 test/fixtures/*.input.css --config .config/.stylelintrc.older.json",
    "lint:stylelint:16": "pnpm dlx stylelint@16 test/fixtures/*.input.css --config .config/.stylelintrc.json",
    "lint:stylelint:latest": "stylelint test/fixtures/*.input.css --config .config/.stylelintrc.json",
    "lint:xo": "xo",
    "prelint:packages": "pnpm run build",
    "prepare": "husky",
    "preserve": "pnpm --filter=css-mixin-polyfill run build",
    "serve": "http-server -p 3000 -o examples/basic-examples.html",
    "test": "pnpm --recursive run test"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@babel/preset-env": "7.29.0",
    "@changesets/changelog-github": "0.6.0",
    "@changesets/cli": "2.30.0",
    "@commitlint/cli": "20.4.4",
    "@commitlint/config-conventional": "20.4.4",
    "@vitest/coverage-v8": "4.0.18",
    "http-server": "14.1.1",
    "husky": "9.1.7",
    "jsdom": "27.2.0",
    "lint-staged": "16.4.0",
    "markdownlint-cli": "0.48.0",
    "microbundle": "0.15.1",
    "npm-run-all2": "8.0.4",
    "playwright": "1.55.1",
    "prettier": "3.8.1",
    "prettier-plugin-organize-imports": "4.3.0",
    "prettier-plugin-pkg": "0.21.2",
    "publint": "0.3.18",
    "stylelint": "17.4.0",
    "stylelint-config-standard": "^40.0.0",
    "vite": "8.0.1",
    "vitest": "4.0.18",
    "xo": "1.2.3"
  },
  "pnpm": {
    "overrides": {
      "qs@>=6.7.0 <=6.14.1": ">=6.14.2",
      "markdown-it@>=13.0.0 <14.1.1": ">=14.1.1",
      "@eslint/plugin-kit@<0.3.4": ">=0.3.4",
      "minimatch@<3.1.3": ">=3.1.3",
      "minimatch@>=5.0.0 <5.1.7": ">=5.1.7",
      "minimatch@>=9.0.0 <9.0.6": ">=9.0.6",
      "minimatch@>=10.0.0 <10.2.1": ">=10.2.1",
      "rollup@>=4.0.0 <4.59.0": ">=4.59.0",
      "rollup@<2.80.0": ">=2.80.0",
      "minimatch@>=5.0.0 <5.1.8": ">=5.1.8",
      "minimatch@>=9.0.0 <9.0.7": ">=9.0.7",
      "minimatch@>=10.0.0 <10.2.3": ">=10.2.3",
      "minimatch@<3.1.4": ">=3.1.4",
      "serialize-javascript@<=7.0.2": ">=7.0.3",
      "ajv@<6.14.0": "^6.14.0",
      "svgo@>=2.1.0 <2.8.1": ">=2.8.1",
      "flatted@<3.4.0": ">=3.4.0",
      "ajv@>=7.0.0-alpha.0 <8.18.0": ">=8.18.0"
    }
  }
}
